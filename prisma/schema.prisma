generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  nip       String?  @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EducationPersonnel {
  id         String           @id @default(cuid())
  full_name  String
  nip        String?          @unique
  email      String?
  position   String
  image_url  String?
  sort_order Int              @default(0)
  createdAt  DateTime         @default(now())
  schedules  SchoolSchedule[]
}

model Post {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  content      String
  category     PostCategory
  images       String[]
  is_published Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Graduation {
  id              String   @id @default(cuid())
  nisn            String   @unique
  student_name    String
  birthday        String?
  gender          String?
  class_name      String?
  is_graduated    Boolean  @default(false)
  graduation_year Int
  createdAt       DateTime @default(now())
}

model AcademicDocument {
  id        String   @id @default(cuid())
  file_name String
  file_path String
  doc_type  DocType
  createdAt DateTime @default(now())
}

model Extracurricular {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  ekskul_name  EkskulName
  content      String
  thumbnail    String?
  is_published Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Facility {
  id        String   @id @default(cuid())
  name      String
  quantity  Int      @default(1)
  image_url String?
  createdAt DateTime @default(now())
}

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SchoolSchedule {
  id          String              @id @default(cuid())
  class_name  String
  period      String
  time        String
  subject     String
  day_of_week String
  teacher_nip String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  teacher     EducationPersonnel? @relation(fields: [teacher_nip], references: [nip])
}

enum Role {
  ADMIN
  EDITOR
  AUTHOR
}

enum PostCategory {
  SUPERVISI_GURU
  ASAS
  ASAJ
  TKA
  KARYA_SISWA
  HUMAS
  KOMITE
  KEMITRAAN
  DOUBLE_TRACK
  OSIS_MPK
}

enum DocType {
  REGULATION
  SCHEDULE
  TEACHING_MATERIAL
}

enum EkskulName {
  Pramuka
  Paskibraka
  Sains_Club
  Basket
  Voli
  Seni_Tari
  Paduan_Suara
  PMR
  Jurnalistik
}
